# RedAgent environment — copy to .env and fill in. NEVER commit .env.

# --- LLM (Groq primary; model is config, never hardcoded) ---
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
CHEAP_LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0

# --- Local fallback (Ollama) ---
FALLBACK_LLM_MODEL=llama3.1:8b

# --- RAG / NVD ---
NVD_API_KEY=

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://redagent:redagent@localhost:5432/redagent

# --- Scope gate (comma-separated IPs / CIDRs; EMPTY = all targets denied) ---
# Lab-only: only private / loopback addresses are ever eligible.
REDAGENT_SCOPE=

# --- Agent loop safety ---
REDAGENT_MAX_STEPS=25
REDAGENT_STEP_SLEEP_S=2
